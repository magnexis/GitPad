{
  "name": "gitpad",
  "version": "1.1.0",
  "description": "Git-powered local-first notes and code workspace.",
  "author": "GitPad Team",
  "main": "target/dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 target/dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/run-electron.cjs .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron:build\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:icons": "node scripts/generate-icons.mjs",
    "build": "tsc -p tsconfig.json && npm run build:electron && npm run build:renderer",
    "start": "npm run build && node scripts/run-electron.cjs .",
    "release:win": "npm run clean && npm run build && npm run build:icons && electron-builder --win nsis --x64 --publish never --config.win.signAndEditExecutable=false",
    "release:win:portable": "npm run clean && npm run build && npm run build:icons && electron-builder --win portable --x64 --publish never --config.win.signAndEditExecutable=false",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "prismjs": "^1.29.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.gitpad.desktop",
    "productName": "GitPad",
    "directories": {
      "output": "target/release",
      "buildResources": "build"
    },
    "files": [
      "target/dist/**",
      "target/dist-electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "target/dist-electron/electron/main.js"
    },
    "asar": true,
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
