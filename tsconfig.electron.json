{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "target/dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"]
  },
  "include": ["backend/**/*.ts", "electron/**/*.ts", "src/shared/**/*.ts"]
}
